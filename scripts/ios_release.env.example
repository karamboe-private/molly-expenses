# Copy to scripts/ios_release.env and fill in values for App Store upload.
# Do not commit ios_release.env (it is gitignored).

# Option A: Apple ID + app-specific password
# Create at https://appleid.apple.com/account/manage -> App-Specific Passwords
# APPLE_ID=you@example.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Option B: App Store Connect API key (recommended for CI)
# Create at https://appstoreconnect.apple.com/access/integrations/api
# APP_STORE_CONNECT_API_KEY_ID=XXXXXXXXXX
# APP_STORE_CONNECT_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APP_STORE_CONNECT_API_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
