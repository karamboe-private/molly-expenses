rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userAccountId() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.accountId;
    }

    function isAccountMember(accountId) {
      return isSignedIn() && userAccountId() == accountId;
    }

    match /receipts/{accountId}/{fileName} {
      allow read: if isAccountMember(accountId);
      allow create, update: if isAccountMember(accountId)
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if isAccountMember(accountId);
    }
  }
}
